# ============================================================
#  Marsa Maroc – Variables d'environnement
#  Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# ── MySQL ─────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=marsa_maroc_db
MYSQL_USER=marsa_user
MYSQL_PASSWORD=marsa_password
MYSQL_HOST=db
MYSQL_PORT=3306

# ── Flask ─────────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=5000
